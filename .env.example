# ============================================================
# FOCO 360° - Variables de entorno
# ============================================================
# Copia este archivo a .env.local y completa con tus credenciales.
# NUNCA subas .env.local al repositorio.
# ============================================================

# ---------- Supabase ----------
# Obtén estos valores en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service Role Key — SOLO usar en server-side. Da acceso total a la DB.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- Admin ----------
# Email del único usuario autorizado para entrar al panel /admin.
# Debe coincidir con el email registrado en Supabase Auth.
ADMIN_EMAIL=tu-email@ejemplo.com

# ---------- Cloudflare R2 ----------
# Crea un bucket en: https://dash.cloudflare.com → R2
# Crea API Token con permisos Read/Write sobre el bucket.
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=foco-360-tours
# Endpoint del bucket: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
# Tiempo de validez de URLs firmadas (en segundos). 3600 = 1 hora.
R2_SIGNED_URL_EXPIRES=3600

# ---------- App ----------
# URL pública de tu app (para construir links de tours)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Nombre de la productora (mostrado en alt del logo y como fallback de texto)
NEXT_PUBLIC_BRAND_NAME=FOCO
# Ruta al logo (en /public). Comenta esta línea para usar el placeholder de texto.
NEXT_PUBLIC_LOGO_URL=/logo.png
